# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key

# Qdrant — локальний Docker (за замовчуванням)
#QDRANT_HOST=localhost
#QDRANT_PORT=6334

# Qdrant Cloud — якщо задано QDRANT_URL, HOST/PORT ігноруються
QDRANT_URL=https://b3e7c9e0-7489-4002-ab46-e4de4ce2c062.europe-west3-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJhY2Nlc3MiOiJyIiwiZXhwIjoxNzgzNzk4NDU2LCJzdWJqZWN0IjoiYXBpLWtleToxM2ZmZDYyOS1lMzI0LTQ2NmEtYjE2Zi1kYzZmYmVlM2RhZWYifQ.pMaP9wNC9jdKGj-56ViHniVQUFz1utvWii-2jN_oUas

QDRANT_COLLECTION=washing_machine

# Embedding
EMBEDDING_MODEL=all-MiniLM-L6-v2

# CLIP model for image search (after changing — re-run build_parts_clip_index.py)
# Option 1: fastest, lowest quality
#CLIP_MODEL=clip-ViT-B-32
# Option 2: better quality, ~3-4x slower on CPU (recommended)
CLIP_MODEL=clip-ViT-B-16
# Option 3: best quality, ~10-15x slower on CPU
#CLIP_MODEL=clip-ViT-L-14

LLM_MODEL=google/gemini-2.5-flash
LLM_FALLBACK_MODEL=google/gemini-2.5-flash-lite
#VISION_MODEL=openai/gpt-4o-mini
VISION_MODEL=openai/gpt-4o
LLM_VISION_ENABLED=false

LLM_CALL_TIMEOUT=45

# Eval classifier (hallucination / refusal / injection checks)
# Option 1: OpenRouter frontier model (same key as OPENROUTER_API_KEY)
EVAL_CLASSIFIER_BASE_URL=https://openrouter.ai/api/v1
EVAL_CLASSIFIER_API_KEY=your_openrouter_api_key
EVAL_CLASSIFIER_MODEL=google/gemini-2.5-flash-lite
# Option 2: local Ollama (no cost, slower)
#EVAL_CLASSIFIER_BASE_URL=http://localhost:11434/v1
#EVAL_CLASSIFIER_API_KEY=ollama
#EVAL_CLASSIFIER_MODEL=mistral:latest

# App
SESSIONS_DB=storage/sessions.db